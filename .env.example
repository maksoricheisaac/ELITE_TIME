# ══════════════════════════════════════════════════════════════════════════════
# .env.example — EliteTime
# Copier ce fichier en .env (backend) ou .env (frontend) et remplir les valeurs.
# NE JAMAIS commiter le .env réel — uniquement ce fichier .env.example
# ══════════════════════════════════════════════════════════════════════════════

# ── BASE DE DONNÉES ────────────────────────────────────────────────────────────
# Chaîne de connexion PostgreSQL complète.
# Format : postgresql://USER:PASSWORD@HOST:PORT/DBNAME?options
# En local : créer une DB dédiée (ex: elitetime_dev) distincte de la prod
DATABASE_URL="postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/DB_NAME?connect_timeout=60&pool_timeout=30&socket_timeout=60"

# ── CHIFFREMENT AES-256-GCM ────────────────────────────────────────────────────
# Clé de 256 bits encodée en hexadécimal (exactement 64 caractères).
# Générer une clé DEV unique :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️  Ne JAMAIS utiliser la même valeur que la clé de production
# ⚠️  La rotation de clé nécessite de rechiffrer toutes les données en DB
ENCRYPTION_KEY="REMPLACER_PAR_64_CHARS_HEX"

# ── LDAP / ACTIVE DIRECTORY ────────────────────────────────────────────────────
# URL du serveur LDAP/AD (ldap:// ou ldaps://)
LDAP_URL="ldap://AD_HOST:389"

# DN complet du compte de service LDAP (lecture seule recommandée)
# Exemple : CN=ServiceAccount,OU=ServiceAccounts,DC=domaine,DC=local
LDAP_BIND_DN="CN=SERVICE_ACCOUNT,OU=OU_NAME,DC=DOMAIN,DC=LOCAL"

# Mot de passe du compte de service LDAP
LDAP_PWD="LDAP_SERVICE_ACCOUNT_PASSWORD"

# Base DN de recherche des utilisateurs
LDAP_BASE_DN="DC=DOMAIN,DC=LOCAL"

# ── MICROSOFT GRAPH API (envoi emails) ────────────────────────────────────────
# Identifiant du tenant Azure AD
# Trouvé dans : Azure Portal → Azure Active Directory → Vue d'ensemble
AZURE_TENANT_ID="XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"

# Client ID de l'application Azure enregistrée
# Trouvé dans : Azure Portal → App registrations → Votre app → Vue d'ensemble
AZURE_CLIENT_ID="XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX"

# Secret client de l'application Azure
# Trouvé dans : Azure Portal → App registrations → Votre app → Certificats & secrets
# ⚠️  Expiration à surveiller (généralement 6 mois ou 1 an)
AZURE_CLIENT_SECRET="AZURE_APP_CLIENT_SECRET"

# Adresse email utilisée comme expéditeur via Microsoft Graph
# Doit correspondre à une boîte mail Exchange valide dans le tenant
GRAPH_SENDER_EMAIL="noreply@votre-domaine.com"

# ── SMTP (fallback — optionnel si Graph API utilisé) ──────────────────────────
# Serveur SMTP de secours (ex: Office 365, Gmail SMTP relay)
SMTP_HOST="smtp.office365.com"
SMTP_PORT=587
SMTP_USER="email@votre-domaine.com"
SMTP_PASS="MOT_DE_PASSE_SMTP"
SMTP_FROM="EliteTime"

# ── SOCKET.IO / WEBSOCKET ─────────────────────────────────────────────────────
# URL publique du serveur WebSocket (côté navigateur)
# En prod : correspond à l'URL derrière le reverse proxy IIS
NEXT_PUBLIC_SOCKET_URL="http://votre-domaine.local"

# Token d'authentification pour les connexions WebSocket internes (workers/scripts)
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SOCKET_TOKEN="REMPLACER_PAR_64_CHARS_HEX"

# ── NESTJS (BACKEND) ───────────────────────────────────────────────────────────
# Origines autorisées pour le CORS (liste séparée par virgules)
NEXT_ALLOWED_ORIGINS="http://votre-domaine.local,http://localhost:3000"

# Activer Secure sur les cookies de session (true en HTTPS, false si HTTP uniquement)
# ⚠️  Doit être "true" dès qu'un certificat TLS est en place
COOKIE_SECURE="false"

# Environnement Node.js
NODE_ENV="development"

# ── NEXT.JS (FRONTEND) ────────────────────────────────────────────────────────
# URL publique de l'API (accessible depuis le navigateur)
NEXT_PUBLIC_API_URL="http://votre-domaine.local/api"

# URL interne de l'API (utilisée par les Server Actions Next.js côté serveur)
# En développement : http://localhost:4000/api
# En production : http://localhost:4000/api (communication interne)
API_URL="http://localhost:4000/api"

# ── IA — OLLAMA ────────────────────────────────────────────────────────────────
# URL du serveur Ollama local (modèle de langage pour l'assistant IA)
OLLAMA_BASE_URL="http://localhost:11434"

# Modèle Ollama utilisé (doit être téléchargé : ollama pull qwen2.5:1.5b)
OLLAMA_MODEL="qwen2.5:1.5b"
