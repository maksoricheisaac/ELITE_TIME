<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!--
      ═══════════════════════════════════════════════════════════════════════
      WEBSOCKET — CRITIQUE
      ═══════════════════════════════════════════════════════════════════════
      "false" bloque l'upgrade HTTP→WS au niveau HTTP.sys, AVANT que URL
      Rewrite soit évalué. Aucune règle socket.io ne peut fonctionner avec
      "false". Le WebSocket Module doit être "true" pour que le pipeline IIS
      laisse passer les handshakes Upgrade vers ARR, qui les forwarde ensuite
      à localhost:4000.

      Pré-requis : rôle Windows "Web-WebSockets" installé
      (Install-WindowsFeature -Name Web-WebSockets)
    -->
    <webSocket enabled="true" />

    <rewrite>
      <!--
        Les serverVariables X-Forwarded-* sont whitelistées dans
        applicationHost.config via appcmd (prepare-iis.ps1).
        La section <allowedServerVariables> est verrouillée (overrideModeDefault=Deny)
        et ne peut PAS être déclarée ici — uniquement dans applicationHost.config.
      -->
      <rules>

        <!--
          ═══════════════════════════════════════════════════════════════════
          RÈGLE 1 — Socket.IO (polling ET websocket, règle unique)
          ═══════════════════════════════════════════════════════════════════
          Pourquoi UNE seule règle sans condition HTTP_UPGRADE ?
          ARR route identiquement les requêtes polling (HTTP/1.1 GET/POST)
          et websocket (HTTP/1.1 Upgrade). La distinction n'est pas du ressort
          d'URL Rewrite : c'est HTTP.sys + le WebSocket Module (enabled="true"
          ci-dessus) qui gèrent physiquement l'upgrade de protocole.
          Ajouter une condition sur HTTP_UPGRADE ne modifie pas le routage,
          elle ajoute juste une branche morte qui peut induire en erreur lors
          du diagnostic.

          Pattern : ^socket\.io(.*) capture aussi la query string
          /socket.io/?EIO=4&transport=polling et transport=websocket
        -->
        <rule name="SocketIO" stopProcessing="true">
          <match url="^socket\.io(.*)" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
            <set name="HTTP_X_FORWARDED_HOST"  value="{HTTP_HOST}" />
            <set name="HTTP_X_REAL_IP"         value="{REMOTE_ADDR}" />
          </serverVariables>
          <action type="Rewrite" url="http://localhost:4000/socket.io{R:1}" />
        </rule>

        <!--
          ═══════════════════════════════════════════════════════════════════
          RÈGLE 2 — Chatbot IA (SSE / streaming)
          ═══════════════════════════════════════════════════════════════════
          Le stream /api/ai/chat/stream utilise Server-Sent Events (SSE).
          Le timeout ARR global doit être >= 600s (configuré dans IIS Manager
          > ARR > Server Proxy Settings > Time-out). Il ne peut pas être
          surchargé par rule dans web.config.
        -->
        <rule name="NestJS-AI" stopProcessing="true">
          <match url="^api/ai/(.*)" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
            <set name="HTTP_X_FORWARDED_HOST"  value="{HTTP_HOST}" />
            <set name="HTTP_X_REAL_IP"         value="{REMOTE_ADDR}" />
          </serverVariables>
          <action type="Rewrite" url="http://localhost:4000/api/ai/{R:1}" />
        </rule>

        <!-- ─── Auth : routes courtes → équivalents NestJS longs ─────── -->

        <rule name="NestJS-Auth-Login" stopProcessing="true">
          <match url="^api/login$" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
            <set name="HTTP_X_FORWARDED_HOST"  value="{HTTP_HOST}" />
            <set name="HTTP_X_REAL_IP"         value="{REMOTE_ADDR}" />
          </serverVariables>
          <action type="Rewrite" url="http://localhost:4000/api/auth/login" />
        </rule>

        <rule name="NestJS-Auth-Logout" stopProcessing="true">
          <match url="^api/logout$" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
            <set name="HTTP_X_FORWARDED_HOST"  value="{HTTP_HOST}" />
            <set name="HTTP_X_REAL_IP"         value="{REMOTE_ADDR}" />
          </serverVariables>
          <action type="Rewrite" url="http://localhost:4000/api/auth/logout" />
        </rule>

        <rule name="NestJS-Auth-Me" stopProcessing="true">
          <match url="^api/me$" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
            <set name="HTTP_X_FORWARDED_HOST"  value="{HTTP_HOST}" />
            <set name="HTTP_X_REAL_IP"         value="{REMOTE_ADDR}" />
          </serverVariables>
          <action type="Rewrite" url="http://localhost:4000/api/auth/me" />
        </rule>

        <!--
          Conservé tel quel : /api/permissions → /api/auth/permissions
          (URL propre exposée côté client)
        -->
        <rule name="NestJS-Auth-Permissions" stopProcessing="true">
          <match url="^api/permissions$" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
            <set name="HTTP_X_FORWARDED_HOST"  value="{HTTP_HOST}" />
            <set name="HTTP_X_REAL_IP"         value="{REMOTE_ADDR}" />
          </serverVariables>
          <action type="Rewrite" url="http://localhost:4000/api/auth/permissions" />
        </rule>

        <!--
          CORRECTIF 404 : /api/user/permissions n'existe pas dans NestJS.
          Le seul endpoint est /api/auth/permissions.
          Cette règle absorbe l'appel du client avant le catch-all NestJS-API
          qui le transmettrait tel quel et obtiendrait un 404.
        -->
        <rule name="NestJS-User-Permissions" stopProcessing="true">
          <match url="^api/user/permissions$" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
            <set name="HTTP_X_FORWARDED_HOST"  value="{HTTP_HOST}" />
            <set name="HTTP_X_REAL_IP"         value="{REMOTE_ADDR}" />
          </serverVariables>
          <action type="Rewrite" url="http://localhost:4000/api/auth/permissions" />
        </rule>

        <!--
          CORRECTIF 404 : /api/admin/users/:id/permissions et /reset
          Ces routes sont gérées par des proxy handlers Next.js (app/api/admin/
          users/[userId]/permissions/) qui transforment l'URL avant d'appeler
          NestJS. Elles ne peuvent PAS aller directement à NestJS car :
          - Le DELETE envoie permissionId dans le body ; NestJS attend l'ID
            dans l'URL (/permissions/user/:id/:permId).
          - Le proxy Next.js extrait l'ID du body et reconstruit l'URL.
        -->
        <rule name="NextJS-Admin-User-Permissions-Reset" stopProcessing="true">
          <match url="^api/admin/users/([^/]+)/permissions/reset$" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
            <set name="HTTP_X_FORWARDED_HOST"  value="{HTTP_HOST}" />
            <set name="HTTP_X_REAL_IP"         value="{REMOTE_ADDR}" />
          </serverVariables>
          <action type="Rewrite" url="http://localhost:3000/api/admin/users/{R:1}/permissions/reset" />
        </rule>

        <rule name="NextJS-Admin-User-Permissions" stopProcessing="true">
          <match url="^api/admin/users/([^/]+)/permissions$" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
            <set name="HTTP_X_FORWARDED_HOST"  value="{HTTP_HOST}" />
            <set name="HTTP_X_REAL_IP"         value="{REMOTE_ADDR}" />
          </serverVariables>
          <action type="Rewrite" url="http://localhost:3000/api/admin/users/{R:1}/permissions" />
        </rule>

        <!-- ─── Catch-all API : toutes les autres routes /api/* ──────── -->
        <rule name="NestJS-API" stopProcessing="true">
          <match url="^api/(.*)" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
            <set name="HTTP_X_FORWARDED_HOST"  value="{HTTP_HOST}" />
            <set name="HTTP_X_REAL_IP"         value="{REMOTE_ADDR}" />
          </serverVariables>
          <action type="Rewrite" url="http://localhost:4000/api/{R:1}" />
        </rule>

        <!--
          ═══════════════════════════════════════════════════════════════════
          RÈGLE FINALE — Next.js (pages, _next/static, images, etc.)
          ═══════════════════════════════════════════════════════════════════
          Catch-all en dernier. Tout ce qui n'a pas été capturé par les règles
          spécifiques ci-dessus part vers le frontend Next.js sur le port 3000.
        -->
        <rule name="NextJS-Frontend" stopProcessing="true">
          <match url="(.*)" />
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
            <set name="HTTP_X_FORWARDED_HOST"  value="{HTTP_HOST}" />
            <set name="HTTP_X_REAL_IP"         value="{REMOTE_ADDR}" />
          </serverVariables>
          <action type="Rewrite" url="http://localhost:3000/{R:1}" />
        </rule>

      </rules>
    </rewrite>

  </system.webServer>
</configuration>
